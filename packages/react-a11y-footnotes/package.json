{
  "name": "react-a11y-footnotes",
  "version": "0.8.0",
  "description": "A reusable React implementation of accessible footnotes.",
  "homepage": "https://github.com/KittyGiraudel/react-a11y-footnotes",
  "license": "MIT",
  "main": "dist/index.js",
  "keywords": [
    "footnotes",
    "footnote",
    "accessibility",
    "a11y",
    "react",
    "component"
  ],
  "author": "Kitty Giraudel (https://kittygiraudel.com)",
  "files": [
    "dist/index.js",
    "dist/styles.css",
    "dist/index.d.ts"
  ],
  "types": "dist/index.d.ts",
  "scripts": {
    "prepare": "npm run build",
    "start": "babel src/index.tsx -o dist/index.js -w --extensions .ts,.tsx",
    "build": "babel src/index.tsx -o dist/index.js --extensions .ts,.tsx && tsc -p tsconfig.json",
    "test": "npm run peer && jest",
    "peer": "npm info . peerDependencies --json  | command sed 's/[\\{\\},]//g ; s/: /@/g' | xargs npm i --no-save",
    "lint": "biome lint .",
    "format": "biome format ."
  },
  "devDependencies": {
    "@babel/cli": "^7.12.7",
    "@babel/preset-env": "^7.12.7",
    "@babel/preset-react": "^7.12.7",
    "@babel/preset-typescript": "^7.28.5",
    "@testing-library/jest-dom": "^6.1.3",
    "@testing-library/react": "^16.0.0",
    "@types/jest": "^30.0.0",
    "@types/prop-types": "^15.7.15",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "babel-jest": "^30.0.5",
    "jest": "^30.0.5",
    "jest-environment-jsdom": "^30.0.5",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "prop-types": "^15.6.0",
    "react": ">=16.0.0",
    "react-dom": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/KittyGiraudel/react-a11y-footnotes/"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "transform": {
      "^.+\\.(t|j)sx?$": "babel-jest"
    }
  }
}
